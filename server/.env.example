# SheDrive Server Environment Variables Template
PORT=3000
NODE_ENV=development

# Database Connection (Supabase PostgreSQL Connection String)
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# JWT Secret Token Key
JWT_SECRET=shedrive_super_secret_jwt_key_2026_fyp
JWT_EXPIRES_IN=30d

# Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME=shedrive
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# CORS & Server Domain
CLIENT_URL=*
